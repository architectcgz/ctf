#!/usr/bin/env bash
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

changed="$(git diff --cached --name-only)"
api_sync_pattern='(^docs/contracts/api-contract-v1\.md$|^docs/architecture/backend/04-api-design\.md$|^code/backend/internal/app/router\.go$|^code/backend/internal/dto/|^code/backend/internal/handler/|^code/backend/internal/module/.+/handler\.go$|^code/backend/pkg/response/|^code/backend/pkg/errcode/)'

needs_sync=0
if command -v rg >/dev/null 2>&1; then
  if echo "$changed" | rg -q "$api_sync_pattern"; then
    needs_sync=1
  fi
else
  if echo "$changed" | grep -Eq "$api_sync_pattern"; then
    needs_sync=1
  fi
fi
# BEGIN HARNESS ENGINEERING: pre-commit
if [[ -x scripts/check-consistency.sh ]]; then
  bash scripts/check-consistency.sh
fi
if [[ -x scripts/check-architecture.sh ]]; then
  bash scripts/check-architecture.sh --quick
fi
# END HARNESS ENGINEERING: pre-commit

if [[ "$needs_sync" -eq 0 ]]; then
  exit 0
fi

python3 scripts/sync_openapi_from_contract.py --contract docs/contracts/api-contract-v1.md --openapi docs/contracts/openapi-v1.yaml

# Auto-stage the generated/updated OpenAPI file.
git add docs/contracts/openapi-v1.yaml
