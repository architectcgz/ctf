# Docker Registry 容器名。
REGISTRY_NAME="ctf-registry"

# 宿主机监听端口。
REGISTRY_PORT="5000"

# 平台后端配置中的 registry server，必须和题目包 runtime.image.ref 的 registry 部分一致。
# 本机演示可以保持 127.0.0.1:5000；如果平台或 Docker 运行节点在其他机器，
# 这里应改成可被那些机器访问的地址，例如 192.168.1.10:5000。不要带 http/https。
REGISTRY_SERVER="127.0.0.1:5000"

# Registry API 访问协议。脚本自带 registry 默认是 http；如果前面加了 TLS 反向代理，可改为 https。
REGISTRY_SCHEME="http"

# Registry 账号。
REGISTRY_USERNAME="ctf"

# Registry 密码。请复制为 deploy-private-registry.conf 后改成自己的强密码。
REGISTRY_PASSWORD="change-this-password"

# 镜像数据和认证文件目录。默认收口到仓库内的 docker/ctf/infra/registry/runtime。
REGISTRY_DATA_DIR="$REPO_ROOT/docker/ctf/infra/registry/runtime/data"
REGISTRY_AUTH_DIR="$REPO_ROOT/docker/ctf/infra/registry/runtime/auth"

# 平台后端与 ctf-api 共用的 registry 环境变量文件。
# 留空表示脚本不写该文件，需要手工注入 container.registry 配置。
CTF_COMPOSE_REGISTRY_ENV_FILE="$REPO_ROOT/docker/ctf/infra/registry/ctf-platform-registry.env"

# 使用的镜像。
REGISTRY_IMAGE="registry:2"
HTPASSWD_IMAGE="httpd:2.4-alpine"

# 容器重启策略。
REGISTRY_RESTART_POLICY="always"
